# ===========================================
# SmartMenu SaaS - Production Environment
# Copy this file to .env and configure values
# ===========================================

APP_NAME="SmartMenu"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

# Logging
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=smartmenu
DB_USERNAME=smartmenu
DB_PASSWORD=your-secure-password-here

# External database port (for direct access)
DB_PORT_EXTERNAL=5432

# Cache & Session (Redis)
CACHE_DRIVER=redis
CACHE_PREFIX=smartmenu
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Queue
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-mail-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Application Ports
APP_PORT=80
APP_PORT_SSL=443

# Filesystem
FILESYSTEM_DISK=local

# Broadcasting (future WebSockets)
BROADCAST_CONNECTION=log

# AWS S3 (for file storage - optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-west-3
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Sentry Error Tracking (optional)
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2

# Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_DECAY=1

# Security
SANCTUM_STATEFUL_DOMAINS=your-domain.com
SESSION_SECURE_COOKIE=true
