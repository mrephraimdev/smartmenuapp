APP_NAME="SmartMenu"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Abidjan

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# For local development with SQLite:
# DB_CONNECTION=sqlite

# For PostgreSQL (recommended for production):
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smartmenu
DB_USERNAME=smartmenu
DB_PASSWORD=

# For Docker environment:
# DB_HOST=postgres
# DB_DATABASE=smartmenu
# DB_USERNAME=smartmenu
# DB_PASSWORD=smartmenu_secret

# ===========================================
# SESSION CONFIGURATION
# ===========================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# For production with Redis:
# SESSION_DRIVER=redis

# ===========================================
# BROADCAST / FILESYSTEM / QUEUE
# ===========================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# For production with Redis:
# QUEUE_CONNECTION=redis

# ===========================================
# CACHE CONFIGURATION
# ===========================================
CACHE_STORE=database
# CACHE_PREFIX=smartmenu_

# For production with Redis:
# CACHE_STORE=redis

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# For Docker environment:
# REDIS_HOST=redis

# ===========================================
# MAIL CONFIGURATION
# ===========================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# For production (SMTP):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ===========================================
# AWS CONFIGURATION (for S3 storage)
# ===========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===========================================
# VITE CONFIGURATION
# ===========================================
VITE_APP_NAME="${APP_NAME}"

# ===========================================
# MENUQR SPECIFIC CONFIGURATION
# ===========================================
# Default currency for new tenants
DEFAULT_CURRENCY=XOF

# QR Code settings
QR_CODE_SIZE=300
QR_CODE_MARGIN=10

# Order settings
ORDER_NUMBER_PREFIX=CMD
ORDER_EXPIRY_HOURS=24

# Rate limiting
API_RATE_LIMIT=60
ORDER_RATE_LIMIT=10

# Multi-tenancy
TENANT_ISOLATION=true

# ===========================================
# MONITORING & ERROR TRACKING
# ===========================================
# Sentry DSN for error monitoring
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT="${APP_ENV}"

# ===========================================
# LOGGING
# ===========================================
# Log channel: stack, single, daily, slack, sentry
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Slack logging webhook (for errors)
LOG_SLACK_WEBHOOK_URL=

# ===========================================
# BACKUPS
# ===========================================
# Backup disk (local, s3, etc.)
BACKUP_DISK=s3
BACKUP_NAME="${APP_NAME}"

# S3 Backup configuration (use AWS credentials above)
# or use DigitalOcean Spaces:
# AWS_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_BUCKET=your-backup-bucket
# AWS_DEFAULT_REGION=nyc3

# ===========================================
# PERFORMANCE MONITORING
# ===========================================
# Laravel Telescope (dev/staging only)
TELESCOPE_ENABLED=false
TELESCOPE_DRIVER=database

# ===========================================
# EXTERNAL SERVICES
# ===========================================
# Slack notifications
SLACK_WEBHOOK_URL=

# Twilio SMS (for notifications)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Pusher/Reverb (for WebSockets)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ===========================================
# PAYMENT GATEWAYS
# ===========================================
# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Paystack (for Mobile Money)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
